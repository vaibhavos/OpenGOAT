{
  "name": "opengoat",
  "version": "1.0.0",
  "description": "Stop organizing your goals. Start crushing them. Gap = Goal - Current.",
  "type": "module",
  "bin": {
    "opengoat": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@types/cors": "^2.8.19",
    "better-sqlite3": "^12.8.0",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^15.1.0",
    "cors": "^2.8.6",
    "express": "^4.19.2",
    "groq-sdk": "^1.1.1",
    "ink": "^4.4.1",
    "inquirer": "^9.3.2",
    "open": "^11.0.0",
    "openai": "^6.32.0",
    "react": "^18.3.1",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "chokidar": "^3.6.0",
    "cli-cursor": "^5.0.0",
    "terminal-size": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/uuid": "^10.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "cli",
    "goal",
    "productivity",
    "ai",
    "missions",
    "opengoat",
    "habit-tracker",
    "goal-tracker",
    "second-brain",
    "obsidian",
    "displacement",
    "plugin-architecture",
    "terminal"
  ],
  "license": "MIT"
}
